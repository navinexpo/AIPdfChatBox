# Base URL for the FastAPI backend. In dev, requests to /api are proxied
# to http://localhost:8000 automatically (see vite.config.ts), so you can
# usually leave this unset locally.
VITE_API_BASE_URL=/api

# Set to "false" to stop using in-memory mock data and call the real
# FastAPI backend instead.
VITE_USE_MOCK_API=true
