# Postgres
DATABASE_URL=postgresql+asyncpg://docked:docked@postgres:5432/docked
DATABASE_URL_SYNC=postgresql+psycopg2://docked:docked@postgres:5432/docked

# ChromaDB (embedded persistent client)
CHROMA_PERSIST_DIR=/data/chroma

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=llama3:8b
OLLAMA_AVAILABLE_MODELS=llama3:8b,qwen2:7b,mistral:7b

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# Chunking
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=80

# RAG
RAG_TOP_K=5
RAG_MAX_CONTEXT_CHARS=8000

# App
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
MAX_UPLOAD_SIZE_MB=25
STORAGE_DIR=/data/storage
LOG_LEVEL=INFO
